---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Now — Abhivir Singh">
  <div class="editorial-container">
    <section class="pt-20 pb-12 border-b border-border">
      <h1
        class="font-serif text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-4"
      >
        Now
      </h1>
      <p class="text-xs text-muted-foreground font-mono">
        Last updated: March 2026
      </p>
    </section>

    <section class="pt-12 pb-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <p class="section-label">Building</p>
          <ul class="space-y-3 text-sm text-muted-foreground">
            <li>
              <span class="text-foreground font-medium">FYP</span> — AI-guided fetal
              ultrasound analysis. MobileUNet for segmentation, L-FUSION for probe
              navigation. Targeting portable devices for low-resource settings.
            </li>
            <li>
              <span class="text-foreground font-medium">abhivir.com</span> — Rebuilding
              this site into a proper digital home.
            </li>
            <li>
              <span class="text-foreground font-medium">Hathin Village</span> — Working
              with a constituency bureaucrat and legislative official to digitise a village.
              Exploring how AI can be deployed cheaply for governance and schools.
            </li>
          </ul>
        </div>
        <div>
          <p class="section-label">Applying</p>
          <ul class="space-y-3 text-sm text-muted-foreground">
            <li>
              <span class="text-foreground font-medium">YC Startup School India</span> —
              Event in Bangalore.
            </li>
            <li>
              <span class="text-foreground font-medium">a16z Speedrun</span> — Applied.
              Planning for summer.
            </li>
            <li>
              <span class="text-foreground font-medium">Z Fellows</span> — Applied.
              Planning for summer.
            </li>
          </ul>
        </div>
        <div>
          <p class="section-label">Thinking About</p>
          <ul class="space-y-3 text-sm text-muted-foreground">
            <li>
              Going back to India after graduating in June. What comes next.
            </li>
            <li>
              What the first product should be — education, governance, or something else
              entirely.
            </li>
            <li>
              Finding a co-founder who complements what I'm good at.
            </li>
          </ul>
        </div>
        <div>
          <p class="section-label">Location</p>
          <p class="text-sm text-muted-foreground">
            London, UK — until June 2026. Then India.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
