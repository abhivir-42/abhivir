---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import HighlightCard from "../components/HighlightCard.astro";
import { work } from "../data/work";
import { highlights } from "../data/highlights";

const featured = work.filter((w) => w.featured);

const featuredHighlightTitles = [
  "Imperial College London",
  "IIT Delhi, B.Tech",
  "Cambridge ENGAA: 9.0/9.0",
  "Imperial Cricket Captain",
  "YC Top 25: Dinner with YC Partners",
  "Wintermute Crypto CTF",
];
const featuredHighlights = featuredHighlightTitles
  .map((title) => highlights.find((h) => h.title === title))
  .filter((h): h is NonNullable<typeof h> => Boolean(h));
---

<BaseLayout>
  <div class="editorial-container">
    <!-- Hero -->
    <section class="pt-20 pb-16 border-b border-border">
      <div class="flex items-start justify-between gap-6 mb-4">
        <h1
          class="font-display text-5xl md:text-6xl font-bold tracking-tight text-foreground leading-[1.1]"
        >
          Abhivir Singh
        </h1>
        <img
          src="/apple-touch-icon.png"
          alt="Abhivir Singh"
          class="w-20 h-20 md:w-24 md:h-24 rounded-sm object-cover border border-border shrink-0"
        />
      </div>
      <div class="max-w-2xl space-y-4 text-sm text-muted-foreground leading-relaxed mt-6">
        <p>
          22, from Faridabad. Studying AI & ML at Imperial College London (MEng Computing, final year).
          Before that, IIT Delhi. Before that, a lot of competitive exams.
        </p>
        <p>
          I like building things end-to-end. I like hard problems and I like shipping.
        </p>
        <p>
          Graduating June 2026. Going back to India to build.
        </p>
      </div>
    </section>

    <!-- Highlights -->
    <section class="pt-12 pb-12 border-b border-border">
      <div class="flex items-center justify-between mb-6">
        <p class="section-label mb-0">Highlights</p>
        <a
          href="/highlights"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          See all highlights &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featuredHighlights.map((item) => (
          <HighlightCard
            title={item.title}
            caption={item.caption}
            date={item.date}
            category={item.category}
            image={item.image}
            imagePosition={item.imagePosition}
            placeholder={item.placeholder}
            href={item.href}
          />
        ))}
      </div>
    </section>

    <!-- Featured Work -->
    <section class="pt-12 pb-12 border-b border-border">
      <div class="flex items-center justify-between mb-6">
        <p class="section-label mb-0">Featured Work</p>
        <a
          href="/work"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          See all work &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {featured.map((project) => (
          <ProjectCard
            title={project.title}
            date={project.date}
            description={project.description}
            tags={project.tags}
            href={project.href}
            slug={project.slug}
            tier={project.tier}
          />
        ))}
      </div>
    </section>

    <!-- Right Now -->
    <section class="pt-12 pb-12 border-b border-border">
      <div class="flex items-center justify-between">
        <p class="section-label mb-0">Right Now</p>
        <a
          href="/now"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          What I'm up to &rarr;
        </a>
      </div>
      <p class="text-sm text-muted-foreground mt-4">
        Final year at Imperial. Building AI for fetal ultrasound analysis. Just back from YC Startup School India in Bengaluru. Writeup coming. Back to India for good after graduating in June.
      </p>
    </section>

    <!-- Contact -->
    <section class="pt-12 pb-16">
      <p class="section-label">Get in Touch</p>
      <p class="text-sm text-muted-foreground mb-6">
        Want to work together, have a question, or just want to say hello?
      </p>
      <div class="flex items-center gap-4 flex-wrap">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 text-sm font-medium text-foreground bg-secondary px-4 py-2 rounded-sm hover:bg-card transition-colors border border-border"
        >
          Send a message &rarr;
        </a>
        <a
          href="https://www.linkedin.com/in/abhivir-singh/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          LinkedIn &nearr;
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
