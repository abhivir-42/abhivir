---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { work } from "../data/work";

const featured = work.filter((w) => w.featured);
---

<BaseLayout>
  <div class="editorial-container">
    <!-- Hero -->
    <section class="pt-20 pb-16 border-b border-border">
      <h1
        class="font-serif text-5xl md:text-6xl font-bold tracking-tight text-foreground leading-[1.1] mb-4"
      >
        Abhivir Singh
      </h1>
      <p class="text-lg text-muted-foreground mb-6">
        I build things. Currently finishing an AI degree at Imperial. Going back to India to build at scale.
      </p>
      <p class="text-base text-muted-foreground leading-relaxed max-w-2xl">
        Final-year MEng Computing (AI & ML) at Imperial College London. I've built AI agent systems,
        won hackathons, written compilers and operating systems from scratch, and sat at the India AI
        Summit with Demis Hassabis. Now I'm figuring out what to build for India.
      </p>
    </section>

    <!-- What I'm About -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">What I'm About</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <p class="text-sm text-muted-foreground leading-relaxed">
            I like building things end-to-end — from the model to the deployment. My strongest work
            has been in <span class="text-foreground font-medium">AI agent systems</span>,
            <span class="text-foreground font-medium">deep learning</span>, and
            <span class="text-foreground font-medium">systems programming</span>. I solo-built an
            AI data science platform with 8+ autonomous agents that's live with data scientists at
            Bosch and Fetch.ai. Before that, I wrote the best operating system and compiler in my
            cohort of 230.
          </p>
        </div>
        <div>
          <p class="text-sm text-muted-foreground leading-relaxed">
            I'm from India and I'm going back. The problems there — in education, governance,
            infrastructure — are massive and under-built-for. AI changes the equation. I've already
            started: contributed to India's national nutrition tracker, built for the government,
            and I'm working with local officials to digitise a constituency. The gap isn't talent.
            It's conviction and agency.
          </p>
        </div>
      </div>
    </section>

    <!-- Featured Work -->
    <section class="pt-12 pb-12 border-b border-border">
      <div class="flex items-center justify-between mb-6">
        <p class="section-label mb-0">Featured Work</p>
        <a
          href="/work"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          See all work &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {featured.map((project) => (
          <ProjectCard
            title={project.title}
            date={project.date}
            description={project.description}
            tags={project.tags}
            href={project.href}
            slug={project.slug}
            tier={project.tier}
          />
        ))}
      </div>
    </section>

    <!-- Right Now -->
    <section class="pt-12 pb-16">
      <div class="flex items-center justify-between mb-6">
        <p class="section-label mb-0">Right Now</p>
        <a
          href="/now"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          More &rarr;
        </a>
      </div>
      <ul class="space-y-3 text-sm text-muted-foreground">
        <li>
          <span class="text-foreground font-medium">FYP:</span> AI-guided fetal ultrasound analysis — deploying deep learning on portable devices for low-resource settings
        </li>
        <li>
          <span class="text-foreground font-medium">Applying:</span> YC Startup School India, a16z Speedrun, Z Fellows
        </li>
        <li>
          <span class="text-foreground font-medium">Building:</span> This website. And figuring out the first product for India.
        </li>
        <li>
          <span class="text-foreground font-medium">Writing:</span> Essays on AI, India, and what it means to build
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>
