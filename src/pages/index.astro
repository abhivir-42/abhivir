---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { work } from "../data/work";

const featured = work.filter((w) => w.featured);
---

<BaseLayout>
  <div class="editorial-container">
    <!-- Hero -->
    <section class="pt-20 pb-16 border-b border-border">
      <h1
        class="font-serif text-5xl md:text-6xl font-bold tracking-tight text-foreground leading-[1.1] mb-4"
      >
        Abhivir Singh
      </h1>
      <div class="max-w-2xl space-y-4 text-sm text-muted-foreground leading-relaxed mt-6">
        <p>
          22, from Faridabad. Studying AI & ML at Imperial College London (MEng Computing, final year).
          Before that, IIT Delhi. Before that, a lot of competitive exams.
        </p>
        <p>
          I like building things end-to-end. I like hard problems and I like shipping.
        </p>
        <p>
          Graduating June 2026. Going back to India to build.
        </p>
      </div>
    </section>

    <!-- Featured Work -->
    <section class="pt-12 pb-12 border-b border-border">
      <div class="flex items-center justify-between mb-6">
        <p class="section-label mb-0">Featured Work</p>
        <a
          href="/work"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          See all work &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {featured.map((project) => (
          <ProjectCard
            title={project.title}
            date={project.date}
            description={project.description}
            tags={project.tags}
            href={project.href}
            slug={project.slug}
            tier={project.tier}
          />
        ))}
      </div>
    </section>

    <!-- Right Now -->
    <section class="pt-12 pb-16">
      <div class="flex items-center justify-between mb-6">
        <p class="section-label mb-0">Right Now</p>
        <a
          href="/now"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          More &rarr;
        </a>
      </div>
      <ul class="space-y-3 text-sm text-muted-foreground">
        <li>
          <span class="text-foreground font-medium">FYP:</span> AI-guided fetal ultrasound analysis for low-resource settings
        </li>
        <li>
          <span class="text-foreground font-medium">Applying:</span> YC Startup School India, a16z Speedrun, Z Fellows
        </li>
        <li>
          <span class="text-foreground font-medium">Exploring:</span> AI for Indian education and governance
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>
