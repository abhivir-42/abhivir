---
import BaseLayout from "../layouts/BaseLayout.astro";
import { papers } from "../data/papers";
---

<BaseLayout title="Papers — Abhivir Singh">
  <div class="editorial-container">
    <section class="pt-20 pb-12 border-b border-border">
      <h1 class="font-serif text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-4">
        Papers
      </h1>
      <p class="text-base text-muted-foreground max-w-2xl">
        Papers I've written, contributed to, or frequently reference in my research.
      </p>
    </section>

    <section class="pt-8 pb-16">
      {papers.map((paper) => (
        <div class="border-b border-border py-6 grid grid-cols-12 gap-4">
          <div class="col-span-12 md:col-span-1">
            <span class="tag-pill">{paper.type}</span>
          </div>
          <div class="col-span-12 md:col-span-7">
            {paper.href ? (
              <a
                href={paper.href}
                target="_blank"
                rel="noopener noreferrer"
                class="font-serif text-base font-semibold text-foreground hover:text-accent transition-colors"
              >
                {paper.title} &nearr;
              </a>
            ) : (
              <span class="font-serif text-base font-semibold text-foreground">
                {paper.title}
              </span>
            )}
            <p class="text-xs text-muted-foreground mt-1">
              {paper.authors} &middot; {paper.venue}
            </p>
          </div>
          <div class="col-span-12 md:col-span-4">
            <p class="text-xs text-muted-foreground leading-relaxed">{paper.note}</p>
          </div>
        </div>
      ))}
    </section>
  </div>
</BaseLayout>
