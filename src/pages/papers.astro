---
import BaseLayout from '../layouts/BaseLayout.astro';
import { papers } from '../data/papers';
---

<BaseLayout title="Papers — Abhivir Singh" description="Research papers by Abhivir Singh.">
  <section>
    <h1 class="text-3xl sm:text-4xl font-bold mb-3">Papers</h1>
    <p class="text-gray-400 mb-10 max-w-2xl">
      Research papers I've authored or contributed to.
    </p>

    <div class="grid gap-6">
      {papers.map((paper) => (
        <div class="card">
          <div class="flex items-start justify-between gap-4 mb-2">
            <h2 class="text-lg font-semibold text-white">
              {paper.link ? (
                <a href={paper.link} target="_blank" rel="noopener noreferrer" class="hover:text-indigo-400 transition-colors">
                  {paper.title} <span class="text-gray-600">&nearr;</span>
                </a>
              ) : (
                paper.title
              )}
            </h2>
          </div>
          <p class="text-sm text-gray-500 mb-3">{paper.authors} &middot; {paper.status}</p>
          <p class="text-sm text-gray-400 leading-relaxed">{paper.description}</p>
          {paper.link && (
            <a href={paper.link} target="_blank" rel="noopener noreferrer" class="link text-sm mt-4 inline-block">
              View paper &rarr;
            </a>
          )}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
