---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';
import { reading } from '../../data/reading';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const typeColors: Record<string, string> = {
  paper: 'text-indigo-300 bg-indigo-500/10 border-indigo-500/20',
  article: 'text-emerald-300 bg-emerald-500/10 border-emerald-500/20',
  book: 'text-amber-300 bg-amber-500/10 border-amber-500/20',
};
---

<BaseLayout title="Blog — Abhivir Singh" description="Reading list and blog posts by Abhivir Singh.">
  <!-- Reading List -->
  <section class="mb-16">
    <h1 class="text-3xl sm:text-4xl font-bold mb-3">Reading List</h1>
    <p class="text-gray-400 mb-8 max-w-2xl">
      Articles, papers, and books I've found valuable. A living collection that grows over time.
    </p>

    <div class="grid gap-3">
      {reading.map((item) => (
        <div class="card">
          <div class="flex items-start justify-between gap-4 mb-1">
            <h3 class="font-medium text-white">
              {item.link ? (
                <a href={item.link} target="_blank" rel="noopener noreferrer" class="hover:text-indigo-400 transition-colors">
                  {item.title} <span class="text-gray-600">&nearr;</span>
                </a>
              ) : (
                item.title
              )}
            </h3>
            <span class={`tag ${typeColors[item.type] || ''}`}>{item.type}</span>
          </div>
          <p class="text-sm text-gray-500 mb-1">{item.author}</p>
          <p class="text-sm text-gray-400">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Blog Posts -->
  <section>
    <h2 class="section-heading">Blog Posts</h2>

    {posts.length > 0 ? (
      <div class="grid gap-4">
        {posts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id.replace(/\.md$/, '')}
            tags={post.data.tags}
          />
        ))}
      </div>
    ) : (
      <p class="text-gray-500">No posts yet. Check back soon.</p>
    )}

    <p class="text-sm text-gray-500 mt-8">
      More posts coming soon.
    </p>
  </section>
</BaseLayout>
