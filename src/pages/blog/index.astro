---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { reading } from "../../data/reading";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Blog & Reading — Abhivir Singh">
  <div class="editorial-container">
    <section class="pt-20 pb-12 border-b border-border">
      <h1 class="font-serif text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-4">
        Blog &amp; Reading
      </h1>
      <p class="text-base text-muted-foreground max-w-2xl">
        Notes, essays, and things I've been reading.
      </p>
    </section>

    <!-- Blog Posts -->
    {sortedPosts.length > 0 && (
      <section class="pt-8 pb-8 border-b border-border">
        <p class="section-label">Writing</p>
        {sortedPosts.map((post) => {
          const dateFormatted = new Date(post.data.date).toLocaleDateString("en-GB", {
            year: "numeric",
            month: "long",
            day: "numeric",
          });
          return (
            <a href={`/blog/${post.id}`} class="block border-b border-border py-6 group last:border-b-0">
              <div class="flex items-start justify-between">
                <h3 class="font-serif text-lg font-semibold text-foreground group-hover:text-accent transition-colors">
                  {post.data.title}
                </h3>
                <span class="text-xs text-muted-foreground whitespace-nowrap ml-4 mt-1 font-mono">
                  {dateFormatted}
                </span>
              </div>
              <p class="text-sm text-muted-foreground leading-relaxed mt-1">
                {post.data.description}
              </p>
            </a>
          );
        })}
      </section>
    )}

    <!-- Reading List -->
    <section class="pt-8 pb-16">
      <p class="section-label">Reading List</p>
      {reading.map((item) => (
        <div class="border-b border-border py-6 grid grid-cols-12 gap-4 items-start">
          <div class="col-span-12 md:col-span-1">
            <span class="tag-pill">{item.type}</span>
          </div>
          <div class="col-span-12 md:col-span-7">
            {item.href ? (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="font-serif text-base font-semibold text-foreground hover:text-accent transition-colors"
              >
                {item.title} &nearr;
              </a>
            ) : (
              <span class="font-serif text-base font-semibold text-foreground">
                {item.title}
              </span>
            )}
            <p class="text-xs text-muted-foreground mt-0.5">{item.author}</p>
          </div>
          <div class="col-span-12 md:col-span-4">
            <p class="text-xs text-muted-foreground leading-relaxed">{item.note}</p>
          </div>
        </div>
      ))}
    </section>
  </div>
</BaseLayout>
