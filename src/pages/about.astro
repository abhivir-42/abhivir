---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About — Abhivir Singh">
  <div class="editorial-container">
    <section class="pt-20 pb-12 border-b border-border">
      <h1
        class="font-serif text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-4"
      >
        About
      </h1>
    </section>

    <section class="pt-12 pb-12 border-b border-border max-w-2xl">
      <p class="text-sm text-muted-foreground leading-relaxed mb-6">
        22, from Faridabad. Studying AI & ML at Imperial College London (MEng Computing, final year).
        Before that, IIT Delhi. Before that, a lot of competitive exams.
      </p>
      <p class="text-sm text-muted-foreground leading-relaxed mb-6">
        I like building things end-to-end. AI agent systems, operating systems, compilers, trading engines.
        I like hard problems and I like shipping.
      </p>
      <p class="text-sm text-muted-foreground leading-relaxed">
        Graduating June 2026. Going back to India after.
      </p>
    </section>

    <section class="pt-12 pb-16">
      <p class="section-label">Elsewhere</p>
      <div class="space-y-3">
        <a href="/work" class="editorial-link text-sm block">
          Work &rarr;
        </a>
        <a href="/highlights" class="editorial-link text-sm block">
          Highlights &rarr;
        </a>
        <a href="/blog" class="editorial-link text-sm block">
          Writing &rarr;
        </a>
        <a href="/now" class="editorial-link text-sm block">
          Now &rarr;
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
