---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact — Abhivir Singh">
  <div class="editorial-container">
    <section class="pt-20 pb-12 border-b border-border">
      <h1
        class="font-display text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-4"
      >
        Contact
      </h1>
      <p class="text-base text-muted-foreground max-w-2xl">
        Want to work together, have a question, or just want to say hello? Drop me a message.
      </p>
    </section>

    <section class="pt-12 pb-12 border-b border-border">
      <div class="max-w-xl">
        <form id="contact-form" class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-medium text-foreground mb-2">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 text-sm bg-background text-foreground border border-border rounded-sm focus:outline-none focus:border-foreground transition-colors"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-foreground mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 text-sm bg-background text-foreground border border-border rounded-sm focus:outline-none focus:border-foreground transition-colors"
              placeholder="you@example.com"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-foreground mb-2">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              class="w-full px-4 py-3 text-sm bg-background text-foreground border border-border rounded-sm focus:outline-none focus:border-foreground transition-colors resize-y"
              placeholder="What's on your mind?"
            ></textarea>
          </div>
          <button
            type="submit"
            class="inline-flex items-center gap-2 text-sm font-medium text-foreground bg-secondary px-6 py-3 rounded-sm hover:bg-card transition-colors border border-border cursor-pointer"
          >
            Send message
          </button>
        </form>

        <div id="form-success" class="hidden py-8">
          <p class="text-foreground font-medium mb-1">Message sent.</p>
          <p class="text-sm text-muted-foreground">Thanks for reaching out — I'll get back to you soon.</p>
        </div>

        <div id="form-error" class="hidden py-4">
          <p class="text-sm text-accent">Something went wrong. Try emailing me directly at as9422@ic.ac.uk.</p>
        </div>
      </div>
    </section>

    <section class="pt-12 pb-16">
      <p class="section-label">Or find me here</p>
      <div class="space-y-0">
        <div class="border-t border-border py-5 grid grid-cols-12 gap-4 items-center">
          <div class="col-span-3 md:col-span-2">
            <span class="tag-pill">email</span>
          </div>
          <div class="col-span-9 md:col-span-10">
            <a
              href="mailto:as9422@ic.ac.uk"
              class="font-content text-base font-semibold text-foreground hover:text-accent transition-colors"
            >
              as9422@ic.ac.uk
            </a>
          </div>
        </div>
        <div class="border-t border-border py-5 grid grid-cols-12 gap-4 items-center">
          <div class="col-span-3 md:col-span-2">
            <span class="tag-pill">linkedin</span>
          </div>
          <div class="col-span-9 md:col-span-10">
            <a
              href="https://www.linkedin.com/in/abhivir-singh/"
              target="_blank"
              rel="noopener noreferrer"
              class="font-content text-base font-semibold text-foreground hover:text-accent transition-colors"
            >
              linkedin.com/in/abhivir-singh &nearr;
            </a>
          </div>
        </div>
        <div class="border-t border-border py-5 grid grid-cols-12 gap-4 items-center">
          <div class="col-span-3 md:col-span-2">
            <span class="tag-pill">github</span>
          </div>
          <div class="col-span-9 md:col-span-10">
            <a
              href="https://github.com/abhivir-42"
              target="_blank"
              rel="noopener noreferrer"
              class="font-content text-base font-semibold text-foreground hover:text-accent transition-colors"
            >
              github.com/abhivir-42 &nearr;
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const success = document.getElementById("form-success")!;
  const error = document.getElementById("form-error")!;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = form.querySelector("button")!;
    btn.textContent = "Sending...";
    btn.setAttribute("disabled", "true");

    const data = {
      name: (form.querySelector("#name") as HTMLInputElement).value,
      email: (form.querySelector("#email") as HTMLInputElement).value,
      message: (form.querySelector("#message") as HTMLTextAreaElement).value,
    };

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        form.classList.add("hidden");
        success.classList.remove("hidden");
      } else {
        throw new Error("Failed");
      }
    } catch {
      error.classList.remove("hidden");
      btn.textContent = "Send message";
      btn.removeAttribute("disabled");
    }
  });
</script>
