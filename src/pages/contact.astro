---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact — Abhivir Singh">
  <div class="editorial-container">
    <section class="pt-20 pb-12 border-b border-border">
      <h1
        class="font-display text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-4"
      >
        Contact
      </h1>
      <p class="text-base text-muted-foreground max-w-2xl">
        Want to work together, have a question, or just want to say hello? Reach out.
      </p>
    </section>

    <section class="pt-12 pb-16">
      <div class="space-y-0">
        <div class="border-t border-border py-5 grid grid-cols-12 gap-4 items-center">
          <div class="col-span-3 md:col-span-2">
            <span class="tag-pill">email</span>
          </div>
          <div class="col-span-9 md:col-span-10">
            <a
              href="mailto:as9422@ic.ac.uk"
              class="font-content text-base font-semibold text-foreground hover:text-accent transition-colors"
            >
              as9422@ic.ac.uk
            </a>
            <p class="text-xs text-muted-foreground mt-0.5">Best way to reach me</p>
          </div>
        </div>
        <div class="border-t border-border py-5 grid grid-cols-12 gap-4 items-center">
          <div class="col-span-3 md:col-span-2">
            <span class="tag-pill">linkedin</span>
          </div>
          <div class="col-span-9 md:col-span-10">
            <a
              href="https://www.linkedin.com/in/abhivir-singh/"
              target="_blank"
              rel="noopener noreferrer"
              class="font-content text-base font-semibold text-foreground hover:text-accent transition-colors"
            >
              linkedin.com/in/abhivir-singh &nearr;
            </a>
          </div>
        </div>
        <div class="border-t border-border py-5 grid grid-cols-12 gap-4 items-center">
          <div class="col-span-3 md:col-span-2">
            <span class="tag-pill">github</span>
          </div>
          <div class="col-span-9 md:col-span-10">
            <a
              href="https://github.com/abhivir-42"
              target="_blank"
              rel="noopener noreferrer"
              class="font-content text-base font-semibold text-foreground hover:text-accent transition-colors"
            >
              github.com/abhivir-42 &nearr;
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
