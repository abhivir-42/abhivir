---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { work } from "../data/work";

const flagship = work.filter((w) => w.tier === "flagship");
const notable = work.filter((w) => w.tier === "notable");
const other = work.filter((w) => w.tier === "other");
---

<BaseLayout title="Work · Abhivir Singh">
  <div class="editorial-container">
    <section class="pt-20 pb-12 border-b border-border">
      <h1
        class="font-display text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-4"
      >
        Work
      </h1>
      <p class="text-base text-muted-foreground max-w-2xl">
        Things I've built, broken, and shipped.
      </p>
    </section>

    <!-- Flagship -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">Flagship</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {flagship.map((project) => (
          <ProjectCard
            title={project.title}
            date={project.date}
            description={project.description}
            tags={project.tags}
            href={project.href}
            slug={project.slug}
            tier={project.tier}
          />
        ))}
      </div>
    </section>

    <!-- Notable -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">Notable</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {notable.map((project) => (
          <ProjectCard
            title={project.title}
            date={project.date}
            description={project.description}
            tags={project.tags}
            href={project.href}
            slug={project.slug}
            tier={project.tier}
          />
        ))}
      </div>
    </section>

    <!-- Other -->
    <section class="pt-12 pb-16">
      <p class="section-label">Other</p>
      <div class="space-y-0">
        {other.map((item) => (
          <div class="border-t border-border py-4 flex items-start justify-between gap-4">
            <div>
              <span class="font-content text-sm font-semibold text-foreground">
                {item.title}
              </span>
              <p class="text-xs text-muted-foreground mt-0.5">
                {item.description}
              </p>
            </div>
            <span class="text-xs font-mono text-muted-foreground whitespace-nowrap">
              {item.date}
            </span>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
