---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { work } from "../data/work";
---

<BaseLayout title="Work — Abhivir Singh">
  <div class="editorial-container">
    <section class="pt-20 pb-12 border-b border-border">
      <h1 class="font-serif text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-4">
        Work
      </h1>
      <p class="text-base text-muted-foreground max-w-2xl">
        Research, engineering, and projects across machine learning, medical imaging, and systems.
      </p>
    </section>

    <section class="pt-12 pb-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {work.map((project) => (
          <ProjectCard
            title={project.title}
            date={project.date}
            description={project.description}
            tags={project.tags}
            href={project.href}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
