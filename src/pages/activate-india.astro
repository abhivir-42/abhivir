---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Activate AI Fellows · Abhivir Singh"
  description="Intro video for the Activate AI Fellows program."
>
  <div class="editorial-container">
    <section class="pt-20 pb-12 border-b border-border">
      <h1
        class="font-display text-4xl md:text-5xl font-bold tracking-tight text-foreground mb-4"
      >
        Activate AI Fellows
      </h1>
      <p class="text-base text-muted-foreground max-w-2xl">
        Intro video. For Aakrit, Pratyush, and the team.
      </p>
    </section>

    <section class="pt-12 pb-16">
      <div class="max-w-3xl">
        <div
          class="relative aspect-[3/2] rounded-sm overflow-hidden bg-black border border-border"
        >
          <video
            controls
            preload="metadata"
            playsinline
            poster="/videos/my-story-activate-poster.jpg"
            class="absolute inset-0 w-full h-full object-contain bg-black"
          >
            <source src="/videos/my-story-activate.mp4" type="video/mp4" />
            <p class="text-sm text-muted-foreground p-4">
              Your browser does not support the video tag.
              <a href="/videos/my-story-activate.mp4" class="underline">Download the MP4</a>.
            </p>
          </video>
        </div>
        <p class="text-xs text-muted-foreground font-mono mt-4">
          ~2 minutes. May 2026.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
