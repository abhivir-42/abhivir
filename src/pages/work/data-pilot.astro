---
import BaseLayout from "../../layouts/BaseLayout.astro";

const repoUrl = "https://github.com/abhivir-42/ai-data-science-platform-hackathon";

const agents = [
  { name: "Data Loader", description: "Ingests CSV files, infers schemas, prepares datasets for downstream agents.", icon: "📂" },
  { name: "Data Cleaning", description: "Generates Python/pandas code to fix missing values, handle outliers, normalize types.", icon: "🧹" },
  { name: "Visualization", description: "Generates interactive Plotly charts from natural language descriptions.", icon: "📊" },
  { name: "Feature Engineering", description: "Writes scikit-learn transformation code based on statistical properties of the data.", icon: "⚙️" },
  { name: "ML Training", description: "Orchestrates H2O AutoML runs and interprets leaderboard results.", icon: "🧠" },
  { name: "Prediction", description: "Runs inference on trained models and explains predictions.", icon: "🎯" },
];

const techStack = [
  { layer: "Frontend", items: "Next.js 14, React 18, TypeScript, Tailwind CSS, Plotly.js" },
  { layer: "Backend", items: "Python 3.10, FastAPI, LangChain, LangGraph" },
  { layer: "LLM", items: "OpenAI-compatible API" },
  { layer: "ML", items: "H2O AutoML, scikit-learn, XGBoost, MLflow" },
  { layer: "Infrastructure", items: "PostgreSQL, Redis, Celery, Docker (7 services)" },
];

const demoSteps = [
  { step: "1", title: "Upload", description: "Drop a CSV. The data loader agent ingests it and infers the schema." },
  { step: "2", title: "Clean", description: "The cleaning agent generates Python code that fixes missing values, removes outliers, normalizes types." },
  { step: "3", title: "Visualize", description: "Describe what you want to see. The viz agent generates interactive Plotly charts." },
  { step: "4", title: "Engineer", description: "Features are transformed into ML-ready representations using generated scikit-learn code." },
  { step: "5", title: "Train", description: "H2O AutoML trains and evaluates models. The LLM interprets the leaderboard and recommends the best one." },
  { step: "6", title: "Predict", description: "Run inference on new data. Get predictions and explanations." },
];
---

<BaseLayout
  title="AI Data Science Platform · Abhivir Singh"
  description="Solo-built platform with 8+ AI agents for end-to-end data science. Live with data scientists at Bosch and Fetch.ai."
>
  <div class="editorial-container">

    <!-- Hero -->
    <section class="pt-20 pb-16 border-b border-border">
      <div class="flex items-center gap-3 mb-6">
        <span class="tag-pill">AI Agents</span>
        <span class="tag-pill">Solo-Built</span>
        <span class="tag-pill">Harness Engineering</span>
      </div>
      <h1 class="font-display text-5xl md:text-6xl font-bold tracking-tight text-foreground leading-[1.1] mb-4">
        AI Data Science Platform
      </h1>
      <p class="text-lg text-muted-foreground mb-6">
        8+ specialised AI agents for end-to-end data science
      </p>
      <p class="text-base text-muted-foreground leading-relaxed max-w-2xl mb-8">
        I built this solo at Fetch.ai. The idea: instead of writing data science code yourself,
        describe what you want in natural language and let a team of AI agents handle the pipeline.
        Each agent is specialised. A supervisor agent orchestrates them. Humans stay in the loop
        at every decision point.
      </p>
      <p class="text-base text-muted-foreground leading-relaxed max-w-2xl mb-8">
        It's live with data scientists at Bosch and Fetch.ai, and non-technical users at HR teams.
        People who'd never written a line of Python are getting Kaggle-level results in minutes.
      </p>
      <div class="flex items-center gap-4">
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-foreground bg-secondary px-4 py-2 rounded-sm hover:bg-card transition-colors border border-border"
        >
          GitHub &nearr;
        </a>
      </div>
    </section>

    <!-- Harness Engineering -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">Harness Engineering</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <p class="text-sm text-muted-foreground leading-relaxed">
          This project is fundamentally about harness engineering: designing the environment,
          constraints, and feedback loops that let AI agents do reliable work. The human's job
          isn't to write code. It's to specify intent, set architectural boundaries, and build
          the scaffolding that keeps agents on track.
        </p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          I built this before the term existed. The problems were the same: agents hallucinate,
          lose context, violate structure. I had to engineer 10+ guardrails, prompt injection
          protection, agent logging, enforced determinism, and orchestration patterns from scratch.
          What OpenAI now calls harness engineering, I was figuring out on my own.
        </p>
      </div>
    </section>

    <!-- Agents -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">The Agents</p>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-3xl mb-8">
        Six specialised agents handle every stage of the pipeline. A LangGraph supervisor
        decomposes high-level goals into multi-agent workflows, decides which agents to invoke
        and in what order, and manages state between steps.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {agents.map((agent) => (
          <div class="editorial-card">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xl">{agent.icon}</span>
              <h3 class="font-content text-base font-semibold text-foreground">{agent.name}</h3>
            </div>
            <p class="text-xs text-muted-foreground leading-relaxed">{agent.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How the LLM is used -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">How the LLM is Used</p>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-3xl mb-10">
        The LLM isn't a chat wrapper. It's the execution engine behind every agent. Three modes:
      </p>

      <div class="space-y-10">
        <div class="grid grid-cols-12 gap-6 items-start">
          <div class="col-span-12 md:col-span-3">
            <h3 class="font-content text-xl font-bold text-foreground mb-1">Coding</h3>
            <p class="text-xs text-muted-foreground">Writes executable code</p>
          </div>
          <div class="col-span-12 md:col-span-9">
            <div class="border border-border p-5 space-y-3">
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">cleaning</span>
                <p class="text-sm text-muted-foreground">Python/pandas to fix missing values, handle outliers, normalize types</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">features</span>
                <p class="text-sm text-muted-foreground">scikit-learn transformation pipelines for encoding, scaling, derived features</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">viz</span>
                <p class="text-sm text-muted-foreground">Plotly chart specs from natural language, rendered in the browser</p>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-12 gap-6 items-start">
          <div class="col-span-12 md:col-span-3">
            <h3 class="font-content text-xl font-bold text-foreground mb-1">Reasoning</h3>
            <p class="text-xs text-muted-foreground">Analyses and decides</p>
          </div>
          <div class="col-span-12 md:col-span-9">
            <div class="border border-border p-5 space-y-3">
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">schema</span>
                <p class="text-sm text-muted-foreground">Detects data quality issues before any code runs</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">charts</span>
                <p class="text-sm text-muted-foreground">Picks chart types based on distribution, column types, cardinality</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">models</span>
                <p class="text-sm text-muted-foreground">Interprets AutoML leaderboard and recommends the best model with reasoning</p>
              </div>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-12 gap-6 items-start">
          <div class="col-span-12 md:col-span-3">
            <h3 class="font-content text-xl font-bold text-foreground mb-1">Orchestration</h3>
            <p class="text-xs text-muted-foreground">Coordinates agents</p>
          </div>
          <div class="col-span-12 md:col-span-9">
            <div class="border border-border p-5 space-y-3">
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">supervisor</span>
                <p class="text-sm text-muted-foreground">LangGraph supervisor decomposes goals into multi-agent workflows</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">routing</span>
                <p class="text-sm text-muted-foreground">Decides which agents to invoke, in what order, manages state</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">example</span>
                <p class="text-sm text-muted-foreground">"Analyse this sales data" → load → clean → visualise → engineer → train</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">Architecture</p>
      <div class="border border-border p-6 md:p-8">
        <pre class="text-xs md:text-sm text-muted-foreground leading-relaxed overflow-x-auto" style="font-family: var(--font-mono);">
User (Natural Language)
        |
        v
  Next.js Frontend (React 18, Tailwind CSS)
        |
        v
  FastAPI Backend
        |
        v
  LangGraph Supervisor (<span class="text-foreground font-medium">LLM orchestration</span>)
        |
   +----+----+----+----+----+
   |    |    |    |    |    |
   v    v    v    v    v    v
 Load Clean  Viz  Feat Train Predict
 Agent Agent Agent Agent Agent Agent
   |    |    |    |    |    |
   +----+----+----+----+----+
        |
        v
  <span class="text-foreground font-medium">LLM</span>: coding + reasoning
        |
  H2O AutoML / MLflow / PostgreSQL / Redis</pre>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">Tech Stack</p>
      <div class="space-y-0">
        {techStack.map((row) => (
          <div class="border-t border-border py-4 grid grid-cols-12 gap-4 items-start">
            <div class="col-span-3 md:col-span-2">
              <span class="tag-pill">{row.layer}</span>
            </div>
            <div class="col-span-9 md:col-span-10">
              <p class="text-sm text-muted-foreground">{row.items}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Demo -->
    <section id="demo" class="pt-12 pb-12 border-b border-border">
      <p class="section-label">How It Works</p>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-3xl mb-8">
        A full data science workflow in six steps. From raw CSV to trained model and predictions.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {demoSteps.map((item) => (
          <div class="editorial-card">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-mono text-accent font-bold">{item.step}</span>
              <h3 class="font-content text-base font-semibold text-foreground">{item.title}</h3>
            </div>
            <p class="text-xs text-muted-foreground leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Links -->
    <section class="pt-12 pb-16">
      <p class="section-label">Links</p>
      <div class="space-y-0">
        <div class="border-t border-border py-5 grid grid-cols-12 gap-4 items-center">
          <div class="col-span-3 md:col-span-2">
            <span class="tag-pill">code</span>
          </div>
          <div class="col-span-9 md:col-span-10">
            <a
              href={repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="font-content text-base font-semibold text-foreground hover:text-accent transition-colors"
            >
              GitHub Repository &nearr;
            </a>
            <p class="text-xs text-muted-foreground mt-0.5">Full source code and documentation</p>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
