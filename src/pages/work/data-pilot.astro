---
import BaseLayout from "../../layouts/BaseLayout.astro";

const repoUrl = "https://github.com/abhivir-42/ai-data-science-platform-hackathon";

const agents = [
  {
    name: "Data Loader",
    description: "Ingests CSV files, infers schemas, and prepares datasets for downstream agents.",
    icon: "📂",
  },
  {
    name: "Data Cleaning",
    description: "GLM-5 generates Python/pandas code to fix missing values, handle outliers, and normalize types.",
    icon: "🧹",
  },
  {
    name: "Visualization",
    description: "GLM-5 generates interactive Plotly chart specifications from natural language descriptions.",
    icon: "📊",
  },
  {
    name: "Feature Engineering",
    description: "GLM-5 writes scikit-learn transformation code based on statistical properties of the data.",
    icon: "⚙️",
  },
  {
    name: "ML Training",
    description: "Orchestrates H2O AutoML training runs and interprets model leaderboard results.",
    icon: "🧠",
  },
  {
    name: "Prediction",
    description: "Runs inference on trained models with new data and explains predictions.",
    icon: "🎯",
  },
];

const techStack = [
  { layer: "Frontend", items: "Next.js 14, React 18, TypeScript, Tailwind CSS, Plotly.js" },
  { layer: "Backend", items: "Python 3.10, FastAPI, LangChain, LangGraph" },
  { layer: "LLM", items: "Z.AI GLM-5 via OpenAI-compatible API" },
  { layer: "ML", items: "H2O AutoML, scikit-learn, XGBoost, MLflow" },
  { layer: "Infrastructure", items: "PostgreSQL, Redis, Celery, Docker (7 services)" },
];

const demoSteps = [
  { step: "1", title: "Upload", description: "Drop a CSV file — the data loader agent ingests it and infers the schema automatically." },
  { step: "2", title: "Clean", description: "The cleaning agent uses GLM-5 to generate Python code that fixes missing values, removes outliers, and normalizes types." },
  { step: "3", title: "Visualize", description: "Describe what you want to see in plain English. GLM-5 generates interactive Plotly charts." },
  { step: "4", title: "Engineer", description: "The feature engineering agent transforms raw columns into ML-ready features using GLM-5-generated scikit-learn code." },
  { step: "5", title: "Train", description: "H2O AutoML trains and evaluates dozens of models. GLM-5 interprets the leaderboard and recommends the best one." },
  { step: "6", title: "Predict", description: "Run inference on new data with the trained model. Get predictions and explanations." },
];
---

<BaseLayout
  title="AI Data Science Platform — Abhivir Singh"
  description="Solo-built platform with 8+ AI agents for end-to-end data science. Live with data scientists at Bosch and Fetch.ai."
>
  <div class="editorial-container">

    <!-- Hero -->
    <section class="pt-20 pb-16 border-b border-border">
      <div class="flex items-center gap-3 mb-6">
        <span class="tag-pill">AI Agents</span>
        <span class="tag-pill">Solo-Built</span>
        <span class="tag-pill">Hackathon Winner</span>
      </div>
      <h1 class="font-serif text-5xl md:text-6xl font-bold tracking-tight text-foreground leading-[1.1] mb-4">
        AI Data Science Platform
      </h1>
      <p class="text-lg text-muted-foreground mb-6">
        <span class="text-foreground font-medium">8+ specialised AI agents</span> for end-to-end data science
      </p>
      <p class="text-base text-muted-foreground leading-relaxed max-w-2xl mb-8">
        Solo-built platform where AI agents coordinate across the full data science pipeline —
        cleaning, visualisation, feature engineering, training, prediction. Humans in the loop
        at every decision point. Live with data scientists at Bosch and Fetch.ai, and non-technical
        users at HR teams. Won the UK AI Agent Hackathon at Imperial.
      </p>
      <div class="flex items-center gap-4">
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium text-foreground bg-secondary px-4 py-2 rounded-sm hover:bg-card transition-colors border border-border"
        >
          GitHub Repository &nearr;
        </a>
        <a
          href="#demo"
          class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          See the demo &darr;
        </a>
      </div>
    </section>

    <!-- Problem -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">The Problem</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <p class="text-sm text-muted-foreground leading-relaxed">
          Data science requires deep expertise most teams lack. The journey from raw data to
          actionable insight — cleaning, transformation, visualization, model training — is
          fragmented across disconnected tools and requires manual stitching at every step.
        </p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          A single analysis might require pandas for cleaning, matplotlib for charts, scikit-learn
          for features, and a separate AutoML tool for training. Each handoff is a point of failure.
          <span class="text-foreground font-medium">Most teams give up before reaching the insight.</span>
        </p>
      </div>
    </section>

    <!-- Solution -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">The Solution</p>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-3xl mb-8">
        DataPilot replaces the fragmented toolchain with a
        <span class="text-foreground font-medium">unified, agent-driven platform</span>.
        Six specialized AI agents — each powered by Z.AI GLM-5 — handle every stage of the pipeline.
        A LangGraph supervisor agent orchestrates them, deciding which agents to invoke, in what order,
        and managing state between steps.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {agents.map((agent) => (
          <div class="editorial-card">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xl">{agent.icon}</span>
              <h3 class="font-serif text-base font-semibold text-foreground">{agent.name}</h3>
            </div>
            <p class="text-xs text-muted-foreground leading-relaxed">{agent.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How GLM-5 Is Used -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">How GLM-5 Powers DataPilot</p>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-3xl mb-10">
        GLM-5 is not a chat wrapper — it is the
        <span class="text-foreground font-medium">execution engine</span> behind every agent.
        Three pillars of integration:
      </p>

      <div class="space-y-10">
        <!-- Coding -->
        <div class="grid grid-cols-12 gap-6 items-start">
          <div class="col-span-12 md:col-span-3">
            <h3 class="font-serif text-xl font-bold text-foreground mb-1">Coding</h3>
            <p class="text-xs text-muted-foreground">GLM-5 writes executable code</p>
          </div>
          <div class="col-span-12 md:col-span-9">
            <div class="border border-border p-5 space-y-3">
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">cleaning</span>
                <p class="text-sm text-muted-foreground">Generates Python/pandas code to fix missing values, handle outliers, normalize column types — executed directly against user data</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">features</span>
                <p class="text-sm text-muted-foreground">Writes scikit-learn transformation pipelines for encoding, scaling, and derived feature creation</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">viz</span>
                <p class="text-sm text-muted-foreground">Generates Plotly chart specifications from natural language — interactive charts rendered in the browser</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Reasoning -->
        <div class="grid grid-cols-12 gap-6 items-start">
          <div class="col-span-12 md:col-span-3">
            <h3 class="font-serif text-xl font-bold text-foreground mb-1">Reasoning</h3>
            <p class="text-xs text-muted-foreground">GLM-5 analyzes and decides</p>
          </div>
          <div class="col-span-12 md:col-span-9">
            <div class="border border-border p-5 space-y-3">
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">schema</span>
                <p class="text-sm text-muted-foreground">Analyzes dataset schemas to detect quality issues before any cleaning code is generated</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">charts</span>
                <p class="text-sm text-muted-foreground">Selects appropriate chart types based on data distribution, column types, and cardinality</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">models</span>
                <p class="text-sm text-muted-foreground">Interprets H2O AutoML leaderboard results and recommends the best model with reasoning</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Orchestration -->
        <div class="grid grid-cols-12 gap-6 items-start">
          <div class="col-span-12 md:col-span-3">
            <h3 class="font-serif text-xl font-bold text-foreground mb-1">Orchestration</h3>
            <p class="text-xs text-muted-foreground">GLM-5 coordinates agents</p>
          </div>
          <div class="col-span-12 md:col-span-9">
            <div class="border border-border p-5 space-y-3">
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">supervisor</span>
                <p class="text-sm text-muted-foreground">LangGraph supervisor agent uses GLM-5 to decompose high-level goals into multi-agent workflows</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">routing</span>
                <p class="text-sm text-muted-foreground">GLM-5 decides which agents to invoke, in what order, and manages state between them</p>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-start gap-3">
                <span class="tag-pill shrink-0">example</span>
                <p class="text-sm text-muted-foreground">"Analyze this sales data" &rarr; load &rarr; clean &rarr; visualize &rarr; engineer features &rarr; train model</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">Architecture</p>
      <div class="border border-border p-6 md:p-8">
        <pre class="text-xs md:text-sm text-muted-foreground leading-relaxed overflow-x-auto" style="font-family: var(--font-mono);">
User (Natural Language)
        |
        v
  Next.js Frontend (React 18, Tailwind CSS)
        |
        v
  FastAPI Backend
        |
        v
  LangGraph Supervisor (<span class="text-foreground font-medium">GLM-5 orchestration</span>)
        |
   +----+----+----+----+----+
   |    |    |    |    |    |
   v    v    v    v    v    v
 Load Clean  Viz  Feat Train Predict
 Agent Agent Agent Agent Agent Agent
   |    |    |    |    |    |
   +----+----+----+----+----+
        |
        v
  <span class="text-foreground font-medium">GLM-5 (Z.AI)</span> — coding + reasoning
        |
  H2O AutoML / MLflow / PostgreSQL / Redis</pre>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="pt-12 pb-12 border-b border-border">
      <p class="section-label">Tech Stack</p>
      <div class="space-y-0">
        {techStack.map((row) => (
          <div class="border-t border-border py-4 grid grid-cols-12 gap-4 items-start">
            <div class="col-span-3 md:col-span-2">
              <span class="tag-pill">{row.layer}</span>
            </div>
            <div class="col-span-9 md:col-span-10">
              <p class="text-sm text-muted-foreground">{row.items}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Demo -->
    <section id="demo" class="pt-12 pb-12 border-b border-border">
      <p class="section-label">How It Works</p>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-3xl mb-8">
        A complete data science workflow in six steps — from raw CSV to trained model and predictions.
        Every step is powered by GLM-5 generating real, executable code.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {demoSteps.map((item) => (
          <div class="editorial-card">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs font-mono text-accent font-bold">{item.step}</span>
              <h3 class="font-serif text-base font-semibold text-foreground">{item.title}</h3>
            </div>
            <p class="text-xs text-muted-foreground leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Links -->
    <section class="pt-12 pb-16">
      <p class="section-label">Links</p>
      <div class="space-y-0">
        <div class="border-t border-border py-5 grid grid-cols-12 gap-4 items-center">
          <div class="col-span-3 md:col-span-2">
            <span class="tag-pill">code</span>
          </div>
          <div class="col-span-9 md:col-span-10">
            <a
              href={repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="font-serif text-base font-semibold text-foreground hover:text-accent transition-colors"
            >
              GitHub Repository &nearr;
            </a>
            <p class="text-xs text-muted-foreground mt-0.5">Full source code, setup instructions, and documentation</p>
          </div>
        </div>
        <div class="border-t border-border py-5 grid grid-cols-12 gap-4 items-center">
          <div class="col-span-3 md:col-span-2">
            <span class="tag-pill">site</span>
          </div>
          <div class="col-span-9 md:col-span-10">
            <a
              href="/"
              class="font-serif text-base font-semibold text-foreground hover:text-accent transition-colors"
            >
              abhivir.com
            </a>
            <p class="text-xs text-muted-foreground mt-0.5">Built by Abhivir Singh — Imperial College London</p>
          </div>
        </div>
        <div class="border-t border-border py-5 grid grid-cols-12 gap-4 items-center">
          <div class="col-span-3 md:col-span-2">
            <span class="tag-pill">track</span>
          </div>
          <div class="col-span-9 md:col-span-10">
            <span class="font-serif text-base font-semibold text-foreground">
              Z.AI — Production-Ready AI Agents
            </span>
            <p class="text-xs text-muted-foreground mt-0.5">UK AI Agent Hackathon at Imperial College London</p>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
