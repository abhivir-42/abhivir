---
const links = [
  { href: 'https://linkedin.com/in/abhivir', label: 'LinkedIn' },
  { href: 'https://github.com/abhivir-42', label: 'GitHub' },
  { href: 'mailto:abhivir@imperial.ac.uk', label: 'Email' },
];
---

<footer class="border-t border-border mt-auto">
  <div class="max-w-4xl mx-auto px-6 py-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-sm text-gray-500">
      &copy; {new Date().getFullYear()} Abhivir Singh
    </p>
    <div class="flex items-center gap-6">
      {links.map(({ href, label }) => (
        <a
          href={href}
          target={href.startsWith('mailto') ? undefined : '_blank'}
          rel={href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          class="text-sm text-gray-500 hover:text-indigo-400 transition-colors"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</footer>
