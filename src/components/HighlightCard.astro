---
interface Props {
  title: string;
  caption: string;
  date: string;
  category: string;
  image?: string;
  imagePosition?: string;
  placeholder: boolean;
  href?: string;
}

const { title, caption, date, category, image, imagePosition, placeholder, href } = Astro.props;
const isExternal = href?.startsWith("http");
const Tag = href ? "a" : "div";
const linkProps = href
  ? { href, ...(isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {}) }
  : {};
---

<Tag
  {...linkProps}
  class:list={[
    "editorial-card flex flex-col",
    href && "group cursor-pointer",
  ]}
>
  <div
    class="aspect-[4/3] rounded-sm mb-4 flex items-center justify-center overflow-hidden bg-secondary"
  >
    {image && !placeholder ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover"
        style={imagePosition ? `object-position: ${imagePosition}` : undefined}
      />
    ) : (
      <span class="text-xs font-mono text-muted-foreground uppercase tracking-wider">
        {category}
      </span>
    )}
  </div>
  <div class="flex items-start justify-between gap-2 mb-1">
    <h3 class:list={[
      "font-content text-sm font-semibold text-foreground",
      href && "group-hover:text-accent transition-colors",
    ]}>
      {title}
      {href && isExternal && <span class="text-muted-foreground text-xs ml-1">&nearr;</span>}
      {href && !isExternal && <span class="text-muted-foreground text-xs ml-1">&rarr;</span>}
    </h3>
    <span class="text-xs font-mono text-muted-foreground whitespace-nowrap">
      {date}
    </span>
  </div>
  <p class="text-xs text-muted-foreground leading-relaxed">{caption}</p>
  <span class="tag-pill mt-2 self-start">{category}</span>
</Tag>
