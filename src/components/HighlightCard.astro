---
interface Props {
  title: string;
  caption: string;
  date: string;
  category: string;
  image?: string;
  placeholder: boolean;
}

const { title, caption, date, category, image, placeholder } = Astro.props;
---

<div class="editorial-card flex flex-col">
  <div
    class="aspect-[4/3] rounded-sm mb-4 flex items-center justify-center overflow-hidden bg-secondary"
  >
    {image && !placeholder ? (
      <img src={image} alt={title} class="w-full h-full object-cover" />
    ) : (
      <span class="text-xs font-mono text-muted-foreground uppercase tracking-wider">
        {category}
      </span>
    )}
  </div>
  <div class="flex items-start justify-between gap-2 mb-1">
    <h3 class="font-serif text-sm font-semibold text-foreground">{title}</h3>
    <span class="text-xs font-mono text-muted-foreground whitespace-nowrap">
      {date}
    </span>
  </div>
  <p class="text-xs text-muted-foreground leading-relaxed">{caption}</p>
  <span class="tag-pill mt-2 self-start">{category}</span>
</div>
