---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/work', label: 'Work' },
  { href: '/papers', label: 'Papers' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-bg/80 backdrop-blur-lg border-b border-border">
  <nav class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-lg font-semibold text-white hover:text-indigo-400 transition-colors">
      abhivir
    </a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-8">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`text-sm transition-colors ${
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'text-white'
              : 'text-gray-400 hover:text-white'
          }`}
        >
          {label}
        </a>
      ))}
    </div>

    <!-- Mobile nav toggle -->
    <button
      id="menu-toggle"
      class="sm:hidden text-gray-400 hover:text-white transition-colors"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile nav menu -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-border bg-bg/95 backdrop-blur-lg">
    <div class="px-6 py-4 flex flex-col gap-4">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`text-sm transition-colors ${
            currentPath === href || (href !== '/' && currentPath.startsWith(href))
              ? 'text-white'
              : 'text-gray-400 hover:text-white'
          }`}
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
