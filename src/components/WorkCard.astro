---
import type { WorkItem } from '../data/work';

interface Props {
  item: WorkItem;
}

const { item } = Astro.props;
---

<div class="card group">
  <div class="flex items-start justify-between gap-4 mb-3">
    <h3 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors">
      {item.link ? (
        <a href={item.link} target="_blank" rel="noopener noreferrer">
          {item.title}
          <span class="inline-block ml-1 text-gray-600 group-hover:text-indigo-400">&nearr;</span>
        </a>
      ) : (
        item.title
      )}
    </h3>
    <span class="text-xs text-gray-500 whitespace-nowrap mt-1">{item.period}</span>
  </div>

  <p class="text-sm text-gray-400 leading-relaxed mb-4">{item.description}</p>

  <div class="flex flex-wrap gap-2">
    {item.tags.map((tag) => (
      <span class="tag">{tag}</span>
    ))}
  </div>
</div>
