---
interface Props {
  title: string;
  description: string;
  date: string;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="card block group">
  <div class="flex items-start justify-between gap-4 mb-2">
    <h3 class="text-lg font-semibold text-white group-hover:text-indigo-400 transition-colors">
      {title}
    </h3>
    <time class="text-xs text-gray-500 whitespace-nowrap mt-1" datetime={date}>
      {formattedDate}
    </time>
  </div>

  <p class="text-sm text-gray-400 leading-relaxed mb-3">{description}</p>

  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  )}
</a>
